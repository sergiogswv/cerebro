# ─── Cerebro — Orquestador ───────────────────────────────
# Copia este archivo a .env y completa los valores

# Modo de orquestación: "rest" (default) | "adk"
ORCHESTRATOR_MODE=rest

# Puerto del Orquestador
PORT=4000

# ─── URLs de los Agentes ─────────────────────────────────
SENTINEL_URL=http://localhost:4001
ARCHITECT_URL=http://localhost:4002
WARDEN_URL=http://localhost:4003
EXECUTOR_URL=http://localhost:4004
NOTIFIER_URL=http://localhost:4100

# ─── Google ADK (solo si ORCHESTRATOR_MODE=adk) ──────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO
